{
  "manifest_version": 3,
  "name": "Wikipedia Simple Switcher",
  "short_name": "Simple Wiki",
  "version": "1.0.1",
  "description": "Shows a small button on Wikipedia articles when a Simple English Wikipedia version exists.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.wikipedia.org/wiki/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://*.wikipedia.org/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "wiki-simple-switcher@jedidiahng2002.local",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
